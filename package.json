{
  "name": "chat-bot-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && mastra build"

{
  "name": "chat-bot-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && mastra build"
  },
  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/libsql": "^1.10.1",
    "@mastra/memory": "^1.18.1",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "mastra": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
